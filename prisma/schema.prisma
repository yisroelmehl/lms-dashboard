generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum DataSource {
  moodle
  manual
}

enum TaskStatus {
  open
  in_progress
  completed
  overdue
}

enum TaskScope {
  student
  class_group
  general
}

enum RecurrenceFrequency {
  daily
  weekly
  biweekly
  monthly
}

enum ServiceRequestType {
  new_shipment
  study_partner
  exam_retake
  material_request
  schedule_change
  other
}

enum ServiceRequestStatus {
  open
  in_progress
  resolved
  cancelled
}

enum ServiceRequestSource {
  web    // created via our web form
  moodle_webhook  // created via Moodle webhook
  manual // created by admin
}

enum EnrollmentStatus {
  active
  suspended
  completed
  withdrawn
  exempt // פטור מסמסטר מסוים
}

enum CompletionState {
  not_started
  in_progress
  complete
  complete_with_pass
  complete_with_fail
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum AdminRole {
  super_admin // מנהל עליון - גישה מלאה כולל חומרי לימוד
  admin       // מנהל - גישה למחולל מבחנים
  rabbi       // רב/מרצה - גישה מוגבלת לקורסים שלו
}

enum PaymentLinkStatus {
  draft       // נוצר אבל עדיין לא נשלח
  sent        // נשלח לתלמיד
  opened      // התלמיד פתח את הקישור
  paid        // שולם בהצלחה
  failed      // נכשל
  cancelled   // בוטל
  expired     // פג תוקף
}

enum PaymentMethod {
  credit_card
  bit
  bank_transfer
  cash
  check
}

enum ExamStatus {
  draft       // טיוטה
  ready       // מוכן לשימוש
  grading     // בתהליך בדיקה
  completed   // הסתיים
}

enum ExamType {
  exam        // מבחן
  assignment  // מטלה
}

enum SubmissionGradingStatus {
  pending     // ממתין לבדיקה
  processing  // בתהליך בדיקה (AI)
  graded      // נבדק
  error       // שגיאה בבדיקה
}

// ============================================================
// ADMIN USERS
// ============================================================

model Admin {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  hashedPassword String
  role           AdminRole @default(admin)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  notes                 Note[]
  taskAssignments       Task[]           @relation("AssignedTo")
  tasksCreated          Task[]           @relation("CreatedBy")
  syncLogs              SyncLog[]
  serviceRequestActions ServiceRequest[] @relation("HandledBy")
  lecturerProfile       Lecturer?
  selfStudyContactLogs  SelfStudyContactLog[]
  examsCreated          ExamTemplate[]       @relation("ExamsCreated")

  @@map("admins")
}

// ============================================================
// LECTURERS (מרצים / רבנים)
// ============================================================

model Lecturer {
  id        String   @id @default(cuid())
  adminId   String?  @unique // Link to Admin user for login/permissions
  
  firstName String
  lastName  String
  email     String?
  phone     String?
  
  // Payment settings
  baseRatePerLesson Float @default(0) // תעריף בסיס לשיעור
  bonusRate         Float @default(0) // תוספת קבועה / נסיעות
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  admin       Admin?     @relation(fields: [adminId], references: [id])
  mainCourses Course[]   @relation("CourseMainLecturer")
  semesters   Semester[] @relation("SemesterLecturer")
  lessons     SyllabusItem[] @relation("LessonLecturer")
  
  @@map("lecturers")
}

// ============================================================
// STUDENTS (synced from Moodle + manual overrides)
// ============================================================

model Student {
  id           String @id @default(cuid())
  moodleUserId Int?   @unique

  // Override pattern fields
  firstNameMoodle   String?
  firstNameOverride String?
  firstNameSource   DataSource @default(moodle)

  lastNameMoodle   String?
  lastNameOverride String?
  lastNameSource   DataSource @default(moodle)

  emailMoodle   String?
  emailOverride String?
  emailSource   DataSource @default(moodle)

  phoneMoodle   String?
  phoneOverride String?
  phoneSource   DataSource @default(moodle)

  idNumberMoodle   String?
  idNumberOverride String?
  idNumberSource   DataSource @default(moodle)

  // Local-only fields (from manual form)
  hebrewName         String?
  city               String?
  address            String?
  dateOfBirth        DateTime?
  torahBackground    String? // רקע תורני
  smichaBackground   String? // רקע בסמיכה
  studyPreferences   String? // העדפות לימוד
  hasChavrusa        Boolean @default(false) // האם יש חברותא
  participationType  String? // אופן השתתפות: פיזי / זום / משולב
  notes              String?

  // Admin-only classification fields
  sector             String? // מגזר
  studyLevel         String? // רמת לימודים (מתקשה, רגיל, מצוין)
  engagementLevel    String? // רמת פעילות והשתתפות (גבוהה, בינונית, נמוכה)
  paymentStatus      String? // סטטוס תשלום (תקין, בפיגור, פטור)
  monthlyPayment     Float?  // תשלום חודשי מדווח (אקסל)
  paymentNotes       String? // הערות תשלום

  // Moodle metadata
  moodleUsername   String?
  moodleLastAccess DateTime?
  moodleRawData    Json?

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollments         Enrollment[]
  semesterEnrollments SemesterEnrollment[]
  activityCompletions ActivityCompletion[]
  grades              Grade[]
  attendanceRecords   Attendance[]
  tasks               TaskStudent[]
  serviceRequests     ServiceRequest[]
  studentNotes        Note[]
  paymentLinks        PaymentLink[]
  payments            Payment[]
  jotformSubmissions  JotformSubmission[]
  termsAcceptances    TermsAcceptance[]
  onboardings         StudentOnboarding[]
  shipments           Shipment[]
  selfStudyEnrollments SelfStudyEnrollment[]
  submissions          StudentSubmission[]
  examSubmissions      ExamSubmission[]
  magicLinks           StudentMagicLink[]
  examAssignments      ExamAssignment[]

  @@map("students")
}

model StudentMagicLink {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  studentId String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_magic_links")
  @@index([studentId])
}

// ============================================================
// TAGS (תגיות - נושאי לימוד, מקצועות וכו׳)
// ============================================================

model Tag {
  id       String @id @default(cuid())
  name     String
  category String @default("subject") // subject, level, track, etc.
  color    String? // צבע לתצוגה (hex)

  // Default pricing for this subject (auto-fill on payment link)
  defaultPriceILS   Float?  // מחיר ברירת מחדל בשקלים
  defaultPriceUSD   Float?  // מחיר ברירת מחדל בדולרים
  defaultNumPayments Int?   // מספר תשלומים ברירת מחדל

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses    CourseTag[]
  studyUnits StudyUnit[]

  @@unique([name, category])
  @@map("tags")
}

model CourseTag {
  courseId String
  tagId   String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_tags")
}

// ============================================================
// COURSES
// ============================================================

model Course {
  id             String @id @default(cuid())
  moodleCourseId Int?   @unique

  fullNameMoodle   String?
  fullNameOverride String?
  fullNameSource   DataSource @default(moodle)

  shortNameMoodle   String?
  shortNameOverride String?
  shortNameSource   DataSource @default(moodle)

  description String?
  isActive    Boolean @default(true)

  // Course Settings (Phase 1)
  dayOfWeek        Int?       // 0-6 (0 = Sunday)
  startDate        DateTime?  // תאריך התחלה לועזי
  hebrewStartDate  String?    // תאריך התחלה עברי
  hours            String?    // שעות (למשל: 18:00-21:00)
  
  mainLecturerId   String?
  mainLecturer     Lecturer?  @relation("CourseMainLecturer", fields: [mainLecturerId], references: [id])

  // Graduation Requirements
  reqExamsCount       Int   @default(0)
  reqGradeAverage     Float @default(0)
  reqAttendancePercent Float @default(0)

  moodleRawData Json?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tags              CourseTag[]
  semesters         Semester[]
  classGroups       ClassGroup[]
  enrollments       Enrollment[]
  syllabusItems     SyllabusItem[]
  grades            Grade[]
  attendanceRecords Attendance[]
  calendarEvents    CalendarEvent[]
  tasks             Task[]
  paymentLinks      PaymentLink[]
  coupons           Coupon[]
  selfStudyEnrollments SelfStudyEnrollment[]
  submissions          StudentSubmission[]
  examTemplates        ExamTemplate[]
  studyUnits           StudyUnit[]

  // Google Drive integration
  driveFolderId    String?
  driveFolderUrl   String?

  @@map("courses")
}

// ============================================================
// SEMESTERS
// ============================================================

model Semester {
  id        String    @id @default(cuid())
  courseId   String
  name      String
  startDate DateTime?
  endDate   DateTime?
  sortOrder Int       @default(0)
  
  lecturerId String?
  lecturer   Lecturer? @relation("SemesterLecturer", fields: [lecturerId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  syllabusItems SyllabusItem[]
  grades        Grade[]
  enrollments   SemesterEnrollment[] // אילו תלמידים רשומים ספציפית לסמסטר זה
  paymentLinks  PaymentLink[]

  @@map("semesters")
}

// ============================================================
// SEMESTER ENROLLMENTS (Tracking start/end per semester)
// ============================================================

model SemesterEnrollment {
  id           String @id @default(cuid())
  studentId    String
  semesterId   String
  enrollmentId String

  status     EnrollmentStatus @default(active)
  joinedAt   DateTime? // תאריך הצטרפות בפועל לסמסטר
  completedAt DateTime? // תאריך סיום (אם רלוונטי)
  notes      String?

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semester   Semester   @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, semesterId])
  @@map("semester_enrollments")
}

// ============================================================
// CLASS GROUPS
// ============================================================

model ClassGroup {
  id            String @id @default(cuid())
  courseId       String
  moodleGroupId Int?   @unique
  name          String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course            Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments       Enrollment[]
  tasks             TaskClassGroup[]
  attendanceRecords Attendance[]
  paymentLinks      PaymentLink[]

  @@map("class_groups")
}

// ============================================================
// ENROLLMENTS
// ============================================================

model Enrollment {
  id           String @id @default(cuid())
  studentId    String
  courseId      String
  classGroupId String?

  statusMoodle   EnrollmentStatus?
  statusOverride EnrollmentStatus?
  statusSource   DataSource        @default(moodle)

  moodleEnrolId Int?
  enrolledAt    DateTime @default(now())
  completedAt   DateTime?

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classGroup ClassGroup? @relation(fields: [classGroupId], references: [id])
  semesterEnrollments SemesterEnrollment[]

  @@unique([studentId, courseId])
  @@map("enrollments")
}

// ============================================================
// SYLLABUS
// ============================================================

model SyllabusItem {
  id          String  @id @default(cuid())
  courseId     String
  semesterId   String?
  title       String
  description String?
  type        String // exam, assignment, quiz, lesson, activity, other
  weight      Float?
  maxScore    Float?
  sortOrder   Int    @default(0)

  moodleCmId         Int?
  moodleActivityType String?
  isMapped           Boolean @default(false)
  quizData           Json?   // Holds the generated quiz questions, options, correct answers
  
  // Publish to Moodle (embed iframe)
  publishedToMoodle  Boolean @default(false)
  moodlePublishedCourseId Int?    // Moodle course ID where activity was planted
  moodlePublishedAt  DateTime?
  embedToken         String?  @unique // JWT signing seed for embed URLs
  
  // Specific to lessons (מפגשים)
  lecturerId         String?
  lecturer           Lecturer? @relation("LessonLecturer", fields: [lecturerId], references: [id])
  paymentBonus       Float @default(0) // תוספת תשלום מיוחדת לשיעור זה בלבד
  paymentStatus      String? // paid, pending, cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course              Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester            Semester?            @relation(fields: [semesterId], references: [id])
  grades              Grade[]
  activityCompletions ActivityCompletion[]
  submissions         StudentSubmission[]

  @@map("syllabus_items")
}

// ============================================================
// ACTIVITY COMPLETION
// ============================================================

model ActivityCompletion {
  id             String @id @default(cuid())
  studentId      String
  syllabusItemId String

  completionStateMoodle   CompletionState?
  completionStateOverride CompletionState?
  completionStateSource   DataSource       @default(moodle)

  completedAtMoodle   DateTime?
  completedAtOverride DateTime?

  moodleTimestamp Int?
  moodleTracking  Int?
  moodleRawData   Json?

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  syllabusItem SyllabusItem @relation(fields: [syllabusItemId], references: [id], onDelete: Cascade)

  @@unique([studentId, syllabusItemId])
  @@map("activity_completions")
}

// ============================================================
// GRADES
// ============================================================

model Grade {
  id             String  @id @default(cuid())
  studentId      String
  courseId        String
  syllabusItemId String?
  semesterId     String?

  scoreMoodle   Float?
  scoreOverride Float?
  scoreSource   DataSource @default(moodle)

  maxScore   Float?
  percentage Float?

  gradeType String    @default("regular") // regular, written_exam, oral_exam, moed_b
  examDate  DateTime?
  comments  String?

  moodleGradeId Int?
  moodleCmId    Int?
  moodleRawData Json?

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  syllabusItem SyllabusItem? @relation(fields: [syllabusItemId], references: [id])
  semester     Semester?     @relation(fields: [semesterId], references: [id])

  @@unique([studentId, syllabusItemId, gradeType])
  @@map("grades")
}

// ============================================================
// ATTENDANCE
// ============================================================

model Attendance {
  id           String @id @default(cuid())
  studentId    String
  courseId      String
  classGroupId String?
  date         DateTime @db.Date

  statusMoodle   AttendanceStatus?
  statusOverride AttendanceStatus?
  statusSource   DataSource        @default(manual)

  moodleCmId Int?
  comments   String?
  recordedBy String?

  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classGroup ClassGroup? @relation(fields: [classGroupId], references: [id])

  @@unique([studentId, courseId, date])
  @@map("attendance")
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(open)
  scope       TaskScope  @default(general)
  priority    Int        @default(0)

  dueDate     DateTime?
  completedAt DateTime?

  courseId         String?
  recurringTaskId String?
  assignedToId    String?
  createdById     String

  notifyOnCreate Boolean  @default(false)
  notifyEmails   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course        Course?        @relation(fields: [courseId], references: [id])
  recurringTask RecurringTask? @relation(fields: [recurringTaskId], references: [id])
  assignedTo    Admin?         @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy     Admin          @relation("CreatedBy", fields: [createdById], references: [id])
  students      TaskStudent[]
  classGroups   TaskClassGroup[]

  @@map("tasks")
}

model TaskStudent {
  taskId    String
  studentId String

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([taskId, studentId])
  @@map("task_students")
}

model TaskClassGroup {
  taskId       String
  classGroupId String

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)

  @@id([taskId, classGroupId])
  @@map("task_class_groups")
}

// ============================================================
// RECURRING TASKS
// ============================================================

model RecurringTask {
  id          String              @id @default(cuid())
  title       String
  description String?
  frequency   RecurrenceFrequency
  dayOfWeek   Int?
  dayOfMonth  Int?
  time        String?

  isActive  Boolean   @default(true)
  nextRunAt DateTime?
  lastRunAt DateTime?

  scope        TaskScope @default(general)
  courseId      String?
  assignedToId String?
  notifyEmails String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generatedTasks Task[]

  @@map("recurring_tasks")
}

// ============================================================
// SERVICE REQUESTS
// ============================================================

model ServiceRequest {
  id        String               @id @default(cuid())
  studentId String
  type      ServiceRequestType
  status    ServiceRequestStatus @default(open)
  source    ServiceRequestSource @default(web)

  title       String
  description String?

  dueDate         DateTime?
  calendarEventId String?

  resolution String?
  resolvedAt DateTime?
  handledById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  handledBy Admin?  @relation("HandledBy", fields: [handledById], references: [id])

  @@map("service_requests")
}

// ============================================================
// NOTES
// ============================================================

model Note {
  id        String   @id @default(cuid())
  studentId String
  authorId  String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  author  Admin   @relation(fields: [authorId], references: [id])

  @@map("notes")
}

// ============================================================
// CALENDAR EVENTS
// ============================================================

model CalendarEvent {
  id            String  @id @default(cuid())
  courseId       String?
  moodleEventId Int?    @unique

  title       String
  description String?
  eventType   String // moodle, task, service_request, custom
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)

  sourceType String?
  sourceId   String?

  moodleRawData Json?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  course Course? @relation(fields: [courseId], references: [id])

  @@map("calendar_events")
}

// ============================================================
// SYNC LOG
// ============================================================

model SyncLog {
  id         String   @id @default(cuid())
  syncType   String
  status     String
  triggeredBy String?

  startedAt   DateTime @default(now())
  completedAt DateTime?

  recordsProcessed Int @default(0)
  recordsCreated   Int @default(0)
  recordsUpdated   Int @default(0)
  recordsSkipped   Int @default(0)
  errors           Int @default(0)

  errorDetails Json?
  metadata     Json?

  triggeredByAdmin Admin? @relation(fields: [triggeredBy], references: [id])

  @@map("sync_logs")
}

// ============================================================
// APP SETTINGS
// ============================================================

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ============================================================
// SALES AGENTS (אנשי מכירות)
// ============================================================

model SalesAgent {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String? @unique
  phone     String?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentLinks PaymentLink[]
  payments     Payment[]

  @@map("sales_agents")
}

// ============================================================
// PAYMENT LINKS (קישורי תשלום)
// ============================================================

model PaymentLink {
  id            String            @id @default(cuid())
  token         String            @unique // Our UUID for the link
  status        PaymentLinkStatus @default(draft)
  isRegistrationOnly Boolean @default(false)

  // Sales context
  salesAgentId  String
  
  // Student info (pre-filled or entered on registration)
  studentId     String?           // linked after registration
  firstName     String
  lastName      String
  email         String?
  phone         String?

  // Internal Notes (Sales to Management)
  financeNotes  String?           // הערות למנהל כספים
  studiesNotes  String?           // הערות למנהל לימודים

  // Course & enrollment targeting
  courseId        String?
  courseName     String?          // Display name (in case courseId is null)
  semesterId     String?          // מחזור לימודים
  classGroupId   String?          // אזור לימודים (Moodle group)
  
  // Pricing
  currency       String           @default("ILS") // ILS or USD
  totalAmount    Float            // Total price
  couponCode     String?          // Coupon code set by agent (null = no coupon option)
  showCouponField Boolean         @default(false) // Show coupon input on registration form
  discountAmount Float            @default(0)
  finalAmount    Float            // After discount
  showTotalOnForm Boolean         @default(false) // false = show monthly only
  
  // Discount group
  discountGroupId String?
  
  // Payment terms
  numPayments    Int              @default(1)   // Number of installments
  chargeDay      Int?             // Day of month for recurring charges (1-28)
  
  // Kesher integration
  kesherPaymentPageId String?     // Payment page ID in Kesher
  kesherToken         String?     // Token from GetLinkToken (legacy)
  kesherTransactionNum String?    // Transaction number from Kesher after payment
  kesherObligationRef  String?    // Obligation reference for standing orders
  
  // Registration data (filled by student via the link)
  registrationData    Json?       // All form data from registration
  termsAcceptedAt     DateTime?
  termsTextAccepted   String?     // The exact text of the terms they accepted
  clientIp            String?     // For legal tracking   // When student accepted terms
  
  // Moodle enrollment
  moodleEnrolled      Boolean     @default(false)
  moodleEnrolledAt    DateTime?
  
  expiresAt    DateTime?
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  salesAgent     SalesAgent     @relation(fields: [salesAgentId], references: [id])
  student        Student?       @relation(fields: [studentId], references: [id])
  course         Course?        @relation(fields: [courseId], references: [id])
  semester       Semester?      @relation(fields: [semesterId], references: [id])
  classGroup     ClassGroup?    @relation(fields: [classGroupId], references: [id])
  discountGroup  DiscountGroup? @relation(fields: [discountGroupId], references: [id])
  payments       Payment[]
  jotformSubmissions JotformSubmission[]

  @@map("payment_links")
}

// ============================================================
// PAYMENTS (תשלומים - history of actual charges)
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  paymentLinkId   String
  salesAgentId    String?
  studentId       String?

  amount          Float
  currency        String        @default("ILS")
  paymentMethod   PaymentMethod @default(credit_card)
  
  // Kesher transaction data
  kesherTransactionNum String?
  kesherOKNum          String?
  kesherStatus         String?
  kesherRawResponse    Json?
  kesherReceiptLink    String?   // Link to digital receipt from Kesher
  kesherDocNumber      String?   // Document number from Kesher
  
  isSuccess       Boolean       @default(false)
  failureReason   String?
  
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  paymentLink  PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
  salesAgent   SalesAgent? @relation(fields: [salesAgentId], references: [id])
  student      Student?    @relation(fields: [studentId], references: [id])

  @@map("payments")
}
// ============================================================
// NOTIFICATIONS (התראות בדשבורד)
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  type      String   // new_student, payment_received, enrollment_created, etc.
  title     String
  message   String
  metadata  Json?    // Additional data (studentId, courseId, paymentLinkId, etc.)
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// ============================================================
// COUPONS (קופונים)
// ============================================================

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique // קוד הקופון (מה שהתלמיד מזין)
  description   String?  // תיאור הקופון
  discountType  String   @default("fixed") // fixed = סכום קבוע, percent = אחוז
  discountValue Float    // הסכום או האחוז
  currency      String   @default("ILS") // ILS or USD (relevant for fixed discounts)
  maxUses       Int?     // מקסימום שימושים (null = ללא הגבלה)
  usedCount     Int      @default(0)
  courseId       String?  // אם מוגבל לקורס מסוים
  isActive      Boolean  @default(true)
  expiresAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course? @relation(fields: [courseId], references: [id])

  @@map("coupons")
}

// ============================================================
// DISCOUNT GROUPS (קבוצות הנחה)
// ============================================================

model DiscountGroup {
  id            String  @id @default(cuid())
  name          String  @unique // e.g. "שליח", "מסלול 5 שנים", "רכישה מרובה"
  description   String? // תיאור הקבוצה
  discountType  String  @default("fixed") // fixed = סכום קבוע, percent = אחוז
  discountValue Float   // הסכום או האחוז
  color         String? // צבע תגית לזיהוי
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentLinks PaymentLink[]

  @@map("discount_groups")
}

// ============================================================
// JOTFORM SUBMISSIONS (הסכמים וטופסים שנשלחו ל-Jotform)
// ============================================================

model JotformSubmission {
  id                  String  @id @default(cuid())
  jotformSubmissionId String  @unique // ID מ-Jotform
  
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  paymentLinkId String?
  paymentLink   PaymentLink? @relation(fields: [paymentLinkId], references: [id], onDelete: SetNull)
  
  firstName  String
  lastName   String
  email      String
  courseId   String?
  courseName String?
  
  // נתונים מ-Jotform
  jotformLink String? // קישור לرויו הטופס ב-Jotform
  
  // metadata
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("jotform_submissions")
  @@index([studentId])
  @@index([paymentLinkId])
}

// ============================================================
// TERMS ACCEPTANCE (אישור תקנון)
// ============================================================

model TermsAcceptance {
  id           String  @id @default(cuid())
  studentId    String
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  firstName    String
  email        String
  courseName   String?
  
  // Signature - JSON string of canvas signature data (base64 or points)
  signature    String
  
  // PDF storage
  pdfContent   Bytes?  // ה-PDF כ-binary blob
  pdfFileName  String? // שם הקובץ
  
  // Metadata
  ipAddress    String?
  userAgent    String?
  
  acceptedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("terms_acceptances")
  @@index([studentId])
  @@index([email])
}

// ============================================================
// STUDENT ONBOARDING (פרוטוקול קליטת תלמיד חדש)
// ============================================================

model StudentOnboarding {
  id           String  @id @default(cuid())
  studentId    String
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  enrollmentId String?

  // 5-step checklist
  callWithDirector     Boolean @default(false) // שיחה עם מנהל הלימודים
  callWithRabbi        Boolean @default(false) // שיחה עם הרב של הכיתה
  materialsSent        Boolean @default(false) // שליחת חומרים
  materialsReceived    Boolean @default(false) // לוודא שהוא קיבל
  connectedToPortal    Boolean @default(false) // לוודא שהוא מחובר לאיזור האישי

  completedAt  DateTime? // Set when all 5 steps done
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  @@map("student_onboardings")
  @@index([studentId])
}

// ============================================================
// SHIPMENTS (משלוחים)
// ============================================================

enum ShipmentCarrier {
  yahav_baldar  // יהב לוגיסטיקה - בלדר (ארץ)
  dhl           // DHL (חו"ל)
  other
}

enum ShipmentStatus {
  pending       // ממתין לאישור/שליחה
  created       // נוצר אצל חברת המשלוחים
  in_transit    // בדרך
  delivered     // נמסר
  cancelled     // בוטל
  returned      // הוחזר
}

model Shipment {
  id           String  @id @default(cuid())
  studentId    String
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  carrier        ShipmentCarrier @default(yahav_baldar)
  status         ShipmentStatus  @default(pending)
  trackingNumber String?         // מספר מעקב מחברת המשלוחים
  
  // Destination address
  recipientName    String
  recipientNameEn  String?  // שם באנגלית (חובה עבור DHL - תווית)
  address          String?
  city             String?
  country          String  @default("IL")
  state            String?  // מדינה (חובה עבור ארה״ב - e.g. NY, CA)
  postalCode       String?  // מיקוד (חובה עבור DHL)
  phone            String?
  email            String?

  // Shipment details
  packageCount   Int     @default(1)
  remarks        String?
  
  // Carrier-specific data
  carrierRef       String?  // מזהה פנימי של חברת המשלוחים (Baldar barcode / DHL tracking)
  carrierStatus    String?  // סטטוס גולמי מחברת המשלוחים
  carrierRawData   Json?    // תשובה מלאה מה-API
  labelData        String?  @db.Text  // PDF label base64 (DHL)

  // DHL-specific fields
  weight           Float?   // משקל בק"ג
  contentDescription String? // תיאור תכולה (לצרכי מכס)

  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("shipments")
  @@index([studentId])
  @@index([trackingNumber])
}

// ============================================================
// SELF-STUDY ENROLLMENTS (תלמידים עצמאיים)
// ============================================================

enum SelfStudyStatus {
  active      // לומד כרגע
  paused      // מושהה
  completed   // סיים
  withdrawn   // פרש
}

model SelfStudyEnrollment {
  id         String          @id @default(cuid())
  studentId  String
  courseId    String          // הקורס שאליו משוייך במודל
  
  status     SelfStudyStatus @default(active)
  studyTopic String?         // נושא לימוד (טקסט חופשי, לפילטר)
  
  // Exam info
  nextExamDate    DateTime?   // מתי הבחינה הקרובה
  examUnits       String?     // על איזה יחידות לימוד (טקסט חופשי)
  examNotes       String?     // הערות מיוחדות לבחינה
  
  // Next contact scheduling
  nextContactDate DateTime?   // מתי ליצור קשר בפעם הבאה
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contactLogs SelfStudyContactLog[]
  
  @@unique([studentId, courseId])
  @@map("self_study_enrollments")
  @@index([studentId])
  @@index([courseId])
  @@index([nextContactDate])
  @@index([status])
}

// ============================================================
// SELF-STUDY CONTACT LOG (יומן תקשורת עם תלמידים עצמאיים)
// ============================================================

model SelfStudyContactLog {
  id                    String @id @default(cuid())
  selfStudyEnrollmentId String
  adminId               String // מי יצר קשר
  
  summary         String   // תקציר השיחה
  nextContactDate DateTime? // מתי ליצור קשר בפעם הבאה
  taskId          String?  // משימה שנוצרה אוטומטית
  
  createdAt DateTime @default(now())
  
  selfStudyEnrollment SelfStudyEnrollment @relation(fields: [selfStudyEnrollmentId], references: [id], onDelete: Cascade)
  admin               Admin               @relation(fields: [adminId], references: [id])
  
  @@map("self_study_contact_logs")
  @@index([selfStudyEnrollmentId])
}

// ============================================================
// STUDENT SUBMISSIONS (מטלות שהוגשו דרך embed iframe)
// ============================================================

model StudentSubmission {
  id             String  @id @default(cuid())
  studentId      String
  syllabusItemId String
  courseId        String

  answers     Json
  grade       Float?
  feedback    String?
  submittedAt DateTime  @default(now())
  gradedAt    DateTime?

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  syllabusItem SyllabusItem @relation(fields: [syllabusItemId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, syllabusItemId])
  @@map("student_submissions")
  @@index([courseId])
  @@index([syllabusItemId])
}

// ============================================================
// LEADS (מתעניינים / לידים)
// ============================================================

model Lead {
  id             String    @id @default(cuid())
  name           String
  phone          String
  email          String?
  courseInterest  String?
  inquiryDate    DateTime  @default(now())
  status         String    @default("new")
  notes          String?
  convertedAt    DateTime?
  studentId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
  @@index([status])
  @@index([phone])
}

// ============================================================
// STUDY UNITS (יחידות לימוד)
// ============================================================

model StudyUnit {
  id               String        @id @default(cuid())
  courseId         String?
  tagId            String?
  studySemesterId  String?
  title            String
  description      String?
  content          String        @db.Text
  unitNumber       Int           @default(1)
  sortOrder        Int           @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course       Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  tag          Tag?          @relation(fields: [tagId], references: [id], onDelete: SetNull)
  studySemester StudySemester? @relation(fields: [studySemesterId], references: [id], onDelete: SetNull)

  examTemplateUnits ExamTemplateUnit[]
  examQuestions     ExamQuestion[]

  @@map("study_units")
  @@index([courseId])
  @@index([tagId])
  @@index([studySemesterId])
}

// ============================================================
// STUDY SUBJECTS & SEMESTERS (ארגון חומרי לימוד)
// ============================================================

model StudySubject {
  id        String          @id @default(cuid())
  name      String          @unique
  createdAt DateTime        @default(now())

  studySemesters StudySemester[]

  @@map("study_subjects")
}

model StudySemester {
  id             String       @id @default(cuid())
  name           String
  number         Int          @default(1)
  studySubjectId String

  studySubject   StudySubject @relation(fields: [studySubjectId], references: [id], onDelete: Cascade)
  studyUnits     StudyUnit[]

  @@map("study_semesters")
  @@index([studySubjectId])
}

// ============================================================
// EXAM TEMPLATES (מבחנים ומטלות - תבניות)
// ============================================================

model ExamTemplate {
  id          String     @id @default(cuid())
  courseId    String?
  title       String
  description String?
  instructions String?   @db.Text
  type        ExamType   @default(exam)
  status      ExamStatus @default(draft)
  timeLimit   Int?
  passingScore Float     @default(60)

  // AI generation context
  aiPrompt         String?
  sourceFileIds    String[]
  sourceFileNames  String[]
  sourceTexts      Json?

  // Generated exam content
  examData    Json?
  totalPoints Float?

  // Scheduling
  examDate    DateTime?
  dueDate     DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course            Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy         Admin?             @relation("ExamsCreated", fields: [createdById], references: [id])
  submissions       ExamSubmission[]
  questions         ExamQuestion[]
  examTemplateUnits ExamTemplateUnit[]
  assignments       ExamAssignment[]

  @@map("exam_templates")
  @@index([courseId])
}

// ============================================================
// EXAM SUBMISSIONS (הגשות מבחנים לבדיקה)
// ============================================================

model ExamSubmission {
  id              String  @id @default(cuid())
  examTemplateId  String
  studentId       String?
  assignmentId    String? @unique

  // File-based flow (paper grading) — kept for backward compat
  fileName        String?
  fileType        String?
  fileData        Bytes?
  extractedText   String?
  studentName     String?

  // Online flow
  answers         Json?     // [{questionId, answer}, ...]
  startedAt       DateTime?
  submittedAt     DateTime?

  // Grading
  gradingStatus   SubmissionGradingStatus @default(pending)
  grade           Float?
  maxGrade        Float?
  feedback        Json?
  aiRawResponse   Json?
  aiPerQuestion   Json?     // [{questionId, score, feedback}]
  aiOverallEval   String?   @db.Text
  teacherFeedback String?   @db.Text

  gradedAt        DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  examTemplate ExamTemplate    @relation(fields: [examTemplateId], references: [id], onDelete: Cascade)
  student      Student?        @relation(fields: [studentId], references: [id])
  assignment   ExamAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@map("exam_submissions")
  @@index([examTemplateId])
  @@index([studentId])
}

// ============================================================
// EXAM ASSIGNMENTS (הקצאת מבחן לתלמידים)
// ============================================================

model ExamAssignment {
  id          String   @id @default(cuid())
  templateId  String
  studentId   String

  // slotKey groups attempts of the same logical exam (מועד א' + מועד ב')
  slotKey     String
  attempt     Int      @default(1)

  deadline    DateTime?  // overrides ExamTemplate.dueDate per student
  publishedAt DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template   ExamTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submission ExamSubmission?

  @@unique([templateId, studentId])
  @@index([studentId, slotKey])
  @@index([templateId])
  @@map("exam_assignments")
}

model ExamTemplateUnit {
  examTemplateId String
  studyUnitId    String

  examTemplate ExamTemplate @relation(fields: [examTemplateId], references: [id], onDelete: Cascade)
  studyUnit    StudyUnit    @relation(fields: [studyUnitId], references: [id], onDelete: Cascade)

  @@id([examTemplateId, studyUnitId])
  @@map("exam_template_units")
}

// ============================================================
// EXAM QUESTIONS (שאלות מבחן/מטלה)
// ============================================================

enum QuestionType {
  open
  multiple_choice
  true_false
  fill_in_the_blank
}

model ExamQuestion {
  id             String       @id @default(cuid())
  examTemplateId String
  studyUnitId    String?

  questionText   String       @db.Text
  questionType   QuestionType @default(open)
  points         Float        @default(10)
  sortOrder      Int          @default(0)

  options        Json?
  correctAnswer  String?      @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  examTemplate   ExamTemplate @relation(fields: [examTemplateId], references: [id], onDelete: Cascade)
  studyUnit      StudyUnit?   @relation(fields: [studyUnitId], references: [id], onDelete: SetNull)

  @@map("exam_questions")
  @@index([examTemplateId])
  @@index([studyUnitId])
}
